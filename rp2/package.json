{
  "name": "rp2",
  "version": "1.1.1",
  "description": "Play Radio Paradise channels with the ability to pause, seek and skip tracks.",
  "main": "./dist/index.js",
  "scripts": {
    "build": "rimraf ./dist && npx tsc --build src && bash fixup.sh",
    "lint": "npx eslint ./src",
    "lint:fix": "npx eslint ./src --fix",
    "format": "prettier --write \"src/**/*.{js,ts,jsx,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{js,ts,jsx,tsx}\""
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/patrickkfkan/volumio-rp2.git"
  },
  "author": "Patrick Kan",
  "license": "MIT",
  "volumio_info": {
    "prettyName": "Radio Paradise (RP2)",
    "plugin_type": "music_service",
    "os": [
      "bookworm"
    ],
    "icon": "fa-music",
    "boot_priority": 10,
    "details": "Play Radio Paradise channels with the ability to pause, seek and skip tracks.",
    "changelog": "",
    "architectures": [
      "amd64",
      "armhf"
    ]
  },
  "engines": {
    "node": ">=20",
    "volumio": ">=0"
  },
  "devDependencies": {
    "@types/fs-extra": "^8.1.2",
    "@types/html-to-text": "^9.0.4",
    "@types/md5": "^2.3.2",
    "@types/node": "^20.5.1",
    "@types/string-format": "^2.0.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unused-imports": "^4.3.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "winston": "^3.8.2"
  },
  "dependencies": {
    "@patrickkfkan/rp.js": "^2.0.1",
    "html-to-text": "^9.0.5",
    "kew": "^0.7.0",
    "lru-cache": "^11.2.6",
    "now-playing-common": "github:patrickkfkan/volumio-now-playing-common#v0.3.4",
    "string-format": "^2.0.0",
    "v-conf": "^1.4.2",
    "volumio-ext-players": "^1.2.0"
  }
}
